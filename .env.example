# Copy to .env and fill in. The .env file is gitignored.

# --- Database -----------------------------------------------------------------
DB_USER=balloon
DB_PASSWORD=change-me-strong-password-here
DB_NAME=balloon

# --- Grafana ------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-also-strong
# Host port to bind Grafana to. nginx talks to the container internally on 3000;
# this only changes how you reach Grafana directly from your host. Override if
# you have something else running on 3030 (or 3000).
GRAFANA_HOST_PORT=3030
# Public-facing root URL. Use https://your-domain once nginx + certbot is up.
GRAFANA_ROOT_URL=http://localhost
GRAFANA_DOMAIN=localhost

# --- Ingester behaviour -------------------------------------------------------
FORECAST_INTERVAL_MIN=60
METAR_INTERVAL_MIN=15
HISTORICAL_LOOKBACK_DAYS=90
INGESTER_USER_AGENT=cappadocia-balloon-conditions/0.1 (+https://github.com/yourname/air-ballon)
LOG_LEVEL=INFO
